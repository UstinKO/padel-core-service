<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- Подключаем стандартные настройки Spring Boot -->
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <!-- Свойства из application.yml/properties -->
    <springProperty scope="context" name="APP_NAME" source="spring.application.name" defaultValue="padel-core"/>
    <springProperty scope="context" name="LOG_PATH" source="logging.file.path" defaultValue="logs"/>
    <springProperty scope="context" name="LOG_MAX_SIZE" source="logging.file.max-size" defaultValue="10MB"/>
    <springProperty scope="context" name="LOG_MAX_HISTORY" source="logging.file.max-history" defaultValue="30"/>
    <springProperty scope="context" name="LOG_TOTAL_SIZE_CAP" source="logging.file.total-size-cap" defaultValue="1GB"/>

    <!-- Переменные окружения (с приоритетом над свойствами) -->
    <property name="LOG_DIR" value="${LOG_PATH:-${java.io.tmpdir}/logs}"/>
    <property name="MAX_FILE_SIZE" value="${LOG_MAX_SIZE:-10MB}"/>
    <property name="MAX_HISTORY" value="${LOG_MAX_HISTORY:-30}"/>
    <property name="TOTAL_SIZE_CAP" value="${LOG_TOTAL_SIZE_CAP:-1GB}"/>

    <!-- ========== АППЕНДЕРЫ ========== -->

    <!-- Консольный аппендер (всегда активен) -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${CONSOLE_LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- Файловый аппендер для всех логов -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/${APP_NAME}.log</file>

        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <!-- Ежедневная ротация с разделением по размеру -->
            <fileNamePattern>${LOG_DIR}/archive/${APP_NAME}.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>

            <!-- Максимальный размер одного файла -->
            <maxFileSize>${MAX_FILE_SIZE}</maxFileSize>

            <!-- Максимальное количество дней хранения -->
            <maxHistory>${MAX_HISTORY}</maxHistory>

            <!-- Общий лимит на все архивы -->
            <totalSizeCap>${TOTAL_SIZE_CAP}</totalSizeCap>
        </rollingPolicy>

        <encoder>
            <pattern>${FILE_LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- Аппендер для ошибок (отдельный файл) -->
    <appender name="ERROR_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/${APP_NAME}-error.log</file>

        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>ERROR</level>
        </filter>

        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/archive/${APP_NAME}-error.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>${MAX_FILE_SIZE}</maxFileSize>
            <maxHistory>${MAX_HISTORY}</maxHistory>
            <totalSizeCap>${TOTAL_SIZE_CAP}</totalSizeCap>
        </rollingPolicy>

        <encoder>
            <pattern>${FILE_LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- Аппендер для JSON логов (для аналитики, опционально) -->
    <appender name="JSON_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/${APP_NAME}-json.log</file>

        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/archive/${APP_NAME}-json.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>${MAX_FILE_SIZE}</maxFileSize>
            <maxHistory>14</maxHistory> <!-- Для JSON храним меньше -->
            <totalSizeCap>500MB</totalSizeCap>
        </rollingPolicy>

        <encoder class="ch.qos.logback.classic.encoder.JsonEncoder"/>
    </appender>

    <!-- ========== ЛОГГЕРЫ ========== -->

    <!-- Логгер для самого приложения -->
    <logger name="com.padle.core" level="INFO" additivity="false">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
        <appender-ref ref="ERROR_FILE"/>
        <appender-ref ref="JSON_FILE"/>
    </logger>

    <!-- Логгер для ошибок (дублирует ERROR_FILE) -->
    <logger name="ERROR_LOGGER" level="ERROR" additivity="false">
        <appender-ref ref="ERROR_FILE"/>
    </logger>

    <!-- SQL логи (отключаем по умолчанию) -->
    <logger name="org.hibernate.SQL" level="WARN"/>
    <logger name="org.hibernate.type.descriptor.sql" level="WARN"/>

    <!-- Spring Security (только предупреждения) -->
    <logger name="org.springframework.security" level="WARN"/>

    <!-- Spring Framework (только предупреждения) -->
    <logger name="org.springframework" level="WARN"/>

    <!-- Hibernate (только предупреждения) -->
    <logger name="org.hibernate" level="WARN"/>

    <!-- ========== ПРОФАЙЛЫ ========== -->

    <!-- Профиль development (подробное логирование) -->
    <springProfile name="dev,development,default">
        <logger name="com.padle.core" level="DEBUG"/>
        <logger name="org.springframework.security" level="DEBUG"/>
        <logger name="org.springframework.web" level="DEBUG"/>
        <logger name="org.hibernate.SQL" level="DEBUG"/>
        <logger name="org.hibernate.type.descriptor.sql" level="TRACE"/>
    </springProfile>

    <!-- Профиль production (только важное) -->
    <springProfile name="prod,production">
        <logger name="com.padle.core" level="INFO"/>
        <logger name="org.springframework.security" level="WARN"/>
        <logger name="org.springframework" level="WARN"/>
        <logger name="org.hibernate" level="WARN"/>

        <!-- В продакшне пишем JSON логи только для важных событий -->
        <logger name="com.padle.core.service.PaymentService" level="INFO" additivity="false">
            <appender-ref ref="JSON_FILE"/>
        </logger>
    </springProfile>

    <!-- Профиль staging (как production, но с debug по запросу) -->
    <springProfile name="staging">
        <logger name="com.padle.core" level="DEBUG"/>
        <logger name="org.springframework.security" level="INFO"/>
    </springProfile>

    <!-- ========== КОРНЕВОЙ ЛОГГЕР ========== -->

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
        <appender-ref ref="ERROR_FILE"/>
    </root>

    <!-- ========== ДОПОЛНИТЕЛЬНЫЕ НАСТРОЙКИ ========== -->

    <!-- Статус логирования (выводит инфо о конфигурации) -->
    <statusListener class="ch.qos.logback.core.status.OnConsoleStatusListener"/>

    <!-- Очистка старых логов при старте (если превышен лимит) -->
    <contextListener class="ch.qos.logback.classic.jul.LevelChangePropagator">
        <resetJUL>true</resetJUL>
    </contextListener>

    <!-- Конвертеры для цветного вывода в консоли (исправлено) -->
    <conversionRule conversionWord="clr" class="org.springframework.boot.logging.logback.ColorConverter"/>
    <conversionRule conversionWord="wex" class="org.springframework.boot.logging.logback.WhitespaceThrowableProxyConverter"/>
    <conversionRule conversionWord="wEx" class="org.springframework.boot.logging.logback.ExtendedWhitespaceThrowableProxyConverter"/>

    <!-- Паттерны для логов -->
    <property name="CONSOLE_LOG_PATTERN" value="%clr(%d{yyyy-MM-dd HH:mm:ss}){faint} %clr(%-5level) %clr(${PID:-}){magenta} %clr(---){faint} %clr([%15.15t]){faint} %clr(%-40.40logger{39}){cyan} %clr(:){faint} %msg%n%wEx"/>
    <property name="FILE_LOG_PATTERN" value="%d{yyyy-MM-dd HH:mm:ss} %-5level ${PID:-} --- [%t] %-40.40logger{39} : %msg%n%wEx"/>
</configuration>